{
  "gates": [
    {
      "name": "lint",
      "command": "$HOME/.bun/bin/bunx tsc --noEmit",
      "required": true
    },
    {
      "name": "test",
      "command": "$HOME/.bun/bin/bun test",
      "required": true
    },
    {
      "name": "build",
      "command": "$HOME/.bun/bin/bun build src/cli.ts --compile --outfile=build/hopper",
      "required": true
    }
  ]
}
